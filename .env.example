# ── Django Core ───────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ── LLM Provider API Keys (LLM Race: Gemini | DeepSeek | Claude | Groq | Ollama)
# All configured providers fire simultaneously — whichever responds first wins.
# You can configure just one or all. At least one must be set.

# Google Gemini  → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# DeepSeek       → https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Anthropic Claude → https://console.anthropic.com/keys
ANTHROPIC_API_KEY=

# ── Open Source Options ───────────────────────────────────────────────────────

# Groq (Free API for Llama 3) → https://console.groq.com/keys
# GROQ_API_KEY=

# Local Ollama (Completely free, runs on your hardware)
# Ensure Ollama is installed (https://ollama.com) and running.
# To enable, set USE_OLLAMA=true
USE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# Legacy OpenAI key (no longer used, kept for reference)
OPENAI_API_KEY=
